---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout title="Page not found — Yumme Momos" description="The page you’re looking for has steamed away.">
  <section class="container-x grid min-h-[60vh] place-items-center py-20 text-center">
    <div class="reveal max-w-md">
      <p class="font-display text-7xl text-chili">404</p>
      <h1 class="mt-4 text-3xl">This page steamed away</h1>
      <p class="mt-3 text-ink/70">The page you’re after isn’t here — but the momos still are.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-primary"><Icon name="arrow" size={18} class="rotate-180" /> Back home</a>
        <a href="/menu" class="btn btn-ghost">See the menu</a>
      </div>
    </div>
  </section>
</BaseLayout>
