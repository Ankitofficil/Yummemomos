---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import ProductCard from '../components/ProductCard.astro';
import AppDownload from '../components/AppDownload.astro';
import ContactStrip from '../components/ContactStrip.astro';
import Marquee from '../components/Marquee.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { site, pillars, products, awards } from '../data/site';

const featured = products.filter((p) => p.featured).slice(0, 6);
---
<BaseLayout
  title="Yumme Momos Manufacturer — Frozen Momos & Fries, Jamshedpur"
  description="Frozen veg momos, non-veg momos and French fries, made hygienically in Jamshedpur since 2019. Order on WhatsApp, get the app, or become a franchise partner."
>
  <!-- ============================ HERO (sunset gradient) ============================ -->
  <section class="panel-sunset relative overflow-hidden">
    <!-- decorative starburst -->
    <svg class="spin-slow pointer-events-none absolute -right-14 -top-14 h-56 w-56 text-fry/40 md:h-72 md:w-72" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0l1.8 7.1L19 2.5l-2.6 6.8 7.6-.9-6.4 4 6.4 3.6-7.5-.7 2.5 7.2-5.2-5-1.8 7.5-1.8-7.5-5.2 5 2.5-7.2-7.5.7 6.4-3.6-6.4-4 7.6.9L5 2.5l5.2 4.6z"/>
    </svg>
    <!-- floating momo doodles -->
    <div class="float-bob-slow pointer-events-none absolute left-[6%] top-[14%] hidden text-white/25 lg:block" style="--bob-rot:-12deg">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M4 14c0-3 3.5-5 8-5s8 2 8 5c0 2-2 3-8 3s-8-1-8-3zM8 9c0-1.5 1.8-3 4-3s4 1.5 4 3" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="float-bob pointer-events-none absolute bottom-[22%] left-[42%] hidden text-white/20 lg:block" style="--bob-rot:14deg">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M4 14c0-3 3.5-5 8-5s8 2 8 5c0 2-2 3-8 3s-8-1-8-3zM8 9c0-1.5 1.8-3 4-3s4 1.5 4 3" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <div class="container-x grid items-center gap-12 py-16 md:grid-cols-2 md:py-24">
      <div class="reveal">
        <span class="eyebrow"><Icon name="star" size={16} /> Est. {site.established} · Jamshedpur</span>
        <h1 class="mt-5 text-[2.7rem] leading-[1.02] text-white sm:text-6xl md:text-[4.2rem]">
          Handmade momos,<br />
          <span class="text-fry">steamed to perfection.</span>
        </h1>
        <p class="mt-5 max-w-lg text-lg text-white/90">
          {site.tagline} Frozen veg &amp; non-veg momos and golden French fries — real ingredients, Himalayan herbs, delivered fresh to homes, retailers and partners.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.whatsapp} target="_blank" rel="noopener" class="btn bg-white text-chili-600 shadow-[0_10px_24px_-8px_rgba(0,0,0,0.4)] hover:-translate-y-1 hover:bg-cream">
            <Icon name="whatsapp" size={20} /> Order on WhatsApp
          </a>
          <a href="/menu" class="btn border-2 border-white/80 text-white hover:bg-white/15">
            See the menu <Icon name="arrow" size={18} />
          </a>
        </div>
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-semibold text-white/85">
          <span class="flex items-center gap-1.5"><Icon name="check" size={16} class="text-fry" /> 100% real ingredients</span>
          <span class="flex items-center gap-1.5"><Icon name="check" size={16} class="text-fry" /> Hygienically made</span>
          <span class="flex items-center gap-1.5"><Icon name="check" size={16} class="text-fry" /> 365-day service</span>
        </div>
      </div>

      <!-- Hero visual with steam -->
      <div class="reveal relative mx-auto w-full max-w-md" style="--reveal-delay:0.15s">
        <div class="float-bob-slow relative aspect-square overflow-hidden rounded-[2.5rem] border-2 border-ink bg-gradient-to-br from-cream to-fry-100 shadow-[8px_10px_0_0_var(--color-ink)]">
          <!-- steam -->
          <div class="steam pointer-events-none absolute left-1/2 top-8 flex -translate-x-1/2 gap-3">
            <span class="block h-16 w-2.5 rounded-full bg-white/80 blur-[3px]"></span>
            <span class="block h-20 w-2.5 rounded-full bg-white/80 blur-[3px]"></span>
            <span class="block h-16 w-2.5 rounded-full bg-white/80 blur-[3px]"></span>
          </div>
          <!-- momo placeholder (TODO: client hi-res hero photo) -->
          <div class="absolute inset-0 grid place-items-center text-ink/25">
            <svg width="150" height="150" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
              <path d="M4 14c0-3 3.5-5 8-5s8 2 8 5c0 2-2 3-8 3s-8-1-8-3zM6 12c0-2 2.7-3.5 6-3.5S18 10 18 12M9 9c0-1.5 1.4-2.6 3-2.6S15 7.5 15 9" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <!-- floating award sticker -->
        <div class="float-bob absolute -bottom-5 -left-3 flex items-center gap-2 rounded-2xl border-2 border-ink bg-white px-4 py-3 text-ink shadow-[4px_4px_0_0_var(--color-ink)]" style="--bob-rot:-3deg">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-fry text-ink"><Icon name="star" size={20} /></span>
          <div class="leading-tight">
            <p class="text-xs font-bold uppercase tracking-wide text-chili-600">Awarded</p>
            <p class="text-sm font-bold">Best Momo Manufacturer, Jharkhand</p>
          </div>
        </div>
        <!-- price-free order sticker -->
        <div class="float-bob-slow absolute -right-2 top-6 rounded-full border-2 border-ink bg-fry px-4 py-2 font-display text-sm font-bold text-ink shadow-[3px_3px_0_0_var(--color-ink)]" style="--bob-rot:6deg">
          Hot &amp; fresh! 🔥
        </div>
      </div>
    </div>
    <WaveDivider />
  </section>

  <!-- ============================ MARQUEE ============================ -->
  <Marquee />

  <!-- ============================ PILLARS ============================ -->
  <section class="container-x py-12 md:py-16" aria-labelledby="pillars-heading">
    <h2 id="pillars-heading" class="sr-only">Why Yumme Momos</h2>
    <div class="grid gap-6 md:grid-cols-3">
      {pillars.map((p, i) => (
        <div class="reveal sticker p-7" style={`--reveal-delay:${i * 0.12}s`}>
          <span class="hover-wiggle grid h-14 w-14 place-items-center rounded-2xl border-2 border-ink bg-chili-50 text-chili shadow-[3px_3px_0_0_var(--color-ink)]">
            <Icon name={p.icon} size={28} />
          </span>
          <h3 class="mt-5 text-2xl">{p.title}</h3>
          <p class="mt-2 text-ink/70">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================ FEATURED PRODUCTS ============================ -->
  <section class="container-x py-14 md:py-20">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <span class="eyebrow"><Icon name="sparkle" size={16} /> Our bestsellers</span>
        <h2 class="mt-4 text-3xl md:text-5xl">Momos worth <span class="text-sunset">coming back for</span></h2>
      </div>
      <a href="/menu" class="btn btn-ghost">Full menu <Icon name="arrow" size={18} /></a>
    </div>
    <div class="mt-9 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((product, i) => (
        <div class="reveal" style={`--reveal-delay:${(i % 3) * 0.1}s`}><ProductCard product={product} /></div>
      ))}
    </div>
  </section>

  <!-- ============================ APP BAND ============================ -->
  <AppDownload />

  <!-- ============================ AWARDS HIGHLIGHT ============================ -->
  <section class="container-x py-14 md:py-20">
    <div class="reveal rounded-[2rem] border-2 border-ink bg-fry-100/60 px-6 py-12 shadow-[6px_7px_0_0_var(--color-ink)] md:px-14">
      <div class="grid gap-8 md:grid-cols-[1fr_1.2fr] md:items-center">
        <div>
          <span class="eyebrow"><Icon name="star" size={16} /> Recognised locally</span>
          <h2 class="mt-3 text-3xl md:text-4xl">Award-winning momos</h2>
          <p class="mt-3 text-ink/70">Proud to be recognised as one of Jharkhand’s best momo manufacturers.</p>
          <a href="/achievements" class="btn btn-ghost mt-6">See achievements <Icon name="arrow" size={18} /></a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {awards.map((a) => (
            <div class="sticker p-5">
              <span class="hover-wiggle grid h-10 w-10 place-items-center rounded-full border-2 border-ink bg-fry text-ink"><Icon name="star" size={22} /></span>
              <h3 class="mt-3 text-lg leading-snug">{a.title}</h3>
              <p class="mt-1 text-sm text-ink/60">{a.by}</p>
              <p class="mt-0.5 text-sm font-bold text-tang-600">{a.date}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ SOCIAL PROOF ============================ -->
  <section class="container-x pb-4">
    <div class="sticker reveal grid gap-6 rounded-[2rem] p-8 md:grid-cols-3 md:p-10">
      <blockquote class="md:col-span-2">
        <p class="font-display text-2xl leading-snug md:text-3xl">
          “Love momo? <span class="text-chili">You’ll never have just one.</span>”
        </p>
        <p class="mt-4 text-ink/70">
          That’s the promise behind every batch — authentic Himalayan flavour, made with native herbs and real ingredients, for the freshest taste in every bite.
        </p>
      </blockquote>
      <div class="flex flex-col justify-center gap-3 rounded-2xl bg-cream-deep/50 p-6 text-center">
        <p class="font-display text-4xl text-chili">6+</p>
        <p class="text-sm text-ink/70">years serving families, retailers &amp; partners since {site.established}</p>
        <!-- TODO: client to confirm any stats (clients served, outlets, etc.) -->
      </div>
    </div>
  </section>

  <!-- ============================ FRANCHISE TEASER ============================ -->
  <section class="container-x py-14 md:py-20">
    <div class="reveal grid gap-8 rounded-[2rem] border-2 border-ink bg-herb-50 px-6 py-12 shadow-[6px_7px_0_0_var(--color-ink)] md:grid-cols-2 md:items-center md:px-14">
      <div>
        <span class="eyebrow text-herb"><Icon name="factory" size={16} /> Partner with us</span>
        <h2 class="mt-3 text-3xl md:text-4xl">Become a Yumme Momos stockist or franchise</h2>
        <p class="mt-3 max-w-md text-ink/70">
          Reliable supply, a proven product and a growing brand. Start a conversation and our team will guide you through the rest.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        <a href="/franchise" class="btn bg-herb text-white hover:bg-herb-600">
          <Icon name="arrow" size={18} /> Become a Partner
        </a>
        <a href={site.whatsappFranchise[0]} target="_blank" rel="noopener" class="btn btn-ghost">
          <Icon name="whatsapp" size={18} /> Franchise WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ============================ CONTACT STRIP ============================ -->
  <ContactStrip />
</BaseLayout>
