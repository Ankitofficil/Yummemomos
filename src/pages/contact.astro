---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site, faqs } from '../data/site';

const mapQuery = encodeURIComponent(
  `${site.name}, ${site.address.full}`
);
const socials = [
  { name: 'whatsapp', href: site.social.whatsapp, label: 'WhatsApp' },
  { name: 'facebook', href: site.social.facebook, label: 'Facebook' },
  { name: 'youtube', href: site.social.youtube, label: 'YouTube' },
  { name: 'google', href: site.social.google, label: 'Google' },
  ...(site.social.instagram ? [{ name: 'instagram', href: site.social.instagram, label: 'Instagram' }] : []),
];
---
<BaseLayout
  title="Contact & Reach Us — Yumme Momos, Jamshedpur"
  description="Reach Yumme Momos in Baridih, Jamshedpur. Call or WhatsApp 9142081374 / 7209412954, email us, or find us on the map. Open Mon–Sun, 9:30 AM–7:30 PM."
>
  <section class="container-x py-12 md:py-16">
    <div class="reveal max-w-2xl">
      <span class="eyebrow"><Icon name="map" size={16} /> Reach us</span>
      <h1 class="mt-3 text-4xl md:text-6xl">Let’s talk momos</h1>
      <p class="mt-4 text-lg text-ink/75">
        Order, ask a question, or start a partnership — we’re here every day of the year.
      </p>
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_1.1fr]">
      <!-- Details -->
      <div class="reveal space-y-4">
        <div class="sticker p-6">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-chili-50 text-chili"><Icon name="phone" size={24} /></span>
          <h2 class="mt-4 text-xl">Call or WhatsApp</h2>
          <div class="mt-2 space-y-1.5">
            {site.phones.map((p) => (
              <p class="flex items-center gap-2">
                <a href={`tel:+${p.value}`} class="font-semibold hover:text-chili">{p.label}</a>
                <span class="rounded-full bg-herb-50 px-2 py-0.5 text-xs font-semibold text-herb">{p.note}</span>
              </p>
            ))}
          </div>
          <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-primary mt-4 w-full">
            <Icon name="whatsapp" size={18} /> Message on WhatsApp
          </a>
        </div>

        <div class="sticker p-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <span class="grid h-11 w-11 place-items-center rounded-2xl bg-fry/20 text-fry"><Icon name="mail" size={24} /></span>
              <h3 class="mt-3 text-lg">Email</h3>
              <a href={`mailto:${site.email}`} class="mt-1 block break-all text-[0.95rem] text-ink/75 hover:text-chili">{site.email}</a>
            </div>
            <div>
              <span class="grid h-11 w-11 place-items-center rounded-2xl bg-herb-50 text-herb"><Icon name="clock" size={24} /></span>
              <h3 class="mt-3 text-lg">Open hours</h3>
              <p class="mt-1 text-[0.95rem] text-ink/75">Mon–Sun · 9:30 AM – 7:30 PM<br />365 days (special holidays only)</p>
            </div>
          </div>
        </div>

        <div class="sticker p-6">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-chili-50 text-chili"><Icon name="map" size={24} /></span>
          <h3 class="mt-3 text-lg">Address</h3>
          <address class="mt-1 not-italic text-[0.95rem] text-ink/75">{site.address.full}</address>
          <div class="mt-4 flex flex-wrap gap-2">
            {socials.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}
                 class="grid h-10 w-10 place-items-center rounded-full border border-ink/15 text-ink/70 transition-colors hover:border-chili hover:text-chili">
                <Icon name={s.name} size={18} />
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="sticker reveal overflow-hidden">
        <iframe
          title="Yumme Momos location map"
          src={`https://maps.google.com/maps?q=${mapQuery}&z=15&output=embed`}
          class="h-full min-h-[420px] w-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-x py-14 md:py-20">
    <div class="reveal max-w-2xl">
      <span class="eyebrow"><Icon name="sparkle" size={16} /> Good to know</span>
      <h2 class="mt-3 text-3xl md:text-5xl">Frequently asked</h2>
    </div>
    <div class="mt-8 grid gap-3">
      {faqs.map((f) => (
        <details class="reveal group sticker p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-semibold">
            {f.q}
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-cream-deep/60 transition-transform group-open:rotate-45">
              <Icon name="close" size={16} class="rotate-45" />
            </span>
          </summary>
          <p class="mt-3 text-ink/75">{f.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
