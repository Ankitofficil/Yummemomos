---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import LiteYouTube from '../components/LiteYouTube.astro';
import ContactStrip from '../components/ContactStrip.astro';
import { awards, videos } from '../data/site';
---
<BaseLayout
  title="Achievements & Awards — Yumme Momos"
  description="Yumme Momos: recognised as one of Jharkhand’s best momo manufacturers. See our awards timeline and press video gallery."
>
  <section class="container-x py-12 md:py-16">
    <div class="reveal max-w-2xl">
      <span class="eyebrow"><Icon name="star" size={16} /> Recognition</span>
      <h1 class="mt-3 text-4xl md:text-6xl">Achievements &amp; awards</h1>
      <p class="mt-4 text-lg text-ink/75">
        Recognition we’re proud of — earned by staying true to real ingredients, honest taste and dependable quality.
      </p>
    </div>

    <!-- Timeline -->
    <div class="mt-12 md:mt-16">
      <ol class="relative ml-3 border-l-2 border-fry/30">
        {awards.map((a) => (
          <li class="reveal relative mb-10 pl-8 last:mb-0">
            <span class="absolute -left-[0.6rem] top-1 grid h-5 w-5 place-items-center rounded-full bg-fry text-white ring-4 ring-cream">
              <Icon name="star" size={12} />
            </span>
            <div class="sticker p-6">
              <p class="text-sm font-semibold text-fry">{a.date}</p>
              <h2 class="mt-1 text-2xl">{a.title}</h2>
              <p class="mt-1 text-ink/70">{a.by}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Video gallery -->
  <section class="container-x py-14 md:py-20">
    <div class="reveal max-w-2xl">
      <span class="eyebrow"><Icon name="play" size={16} /> In the press</span>
      <h2 class="mt-3 text-3xl md:text-5xl">Watch us in action</h2>
      <p class="mt-3 text-ink/70">Tap any video to play — nothing loads until you click.</p>
    </div>
    <div class="mt-9 grid gap-6 sm:grid-cols-2">
      {videos.map((v) => (
        <div class="reveal"><LiteYouTube id={v.id} title={v.title} /></div>
      ))}
    </div>
  </section>

  <ContactStrip />
</BaseLayout>
