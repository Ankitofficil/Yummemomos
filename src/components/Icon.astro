const filled = ['whatsapp', 'facebook', 'youtube', 'instagram', 'google', 'play'];
const isFilled = filled.includes(name);
const d = paths[name] ?? '';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? 'none' : 'currentColor'}
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-hidden="true"
><path d={d} /></svg>
