---
import StoreBadges from './StoreBadges.astro';
import Icon from './Icon.astro';
---
<section class="container-x py-14 md:py-20">
  <div class="reveal relative overflow-hidden rounded-[2rem] bg-ink px-6 py-12 text-cream shadow-[6px_7px_0_0_var(--color-fry)] md:px-14 md:py-16">
    <!-- decorative glow -->
    <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-chili/25 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 left-1/3 h-56 w-56 rounded-full bg-fry/20 blur-3xl"></div>

    <div class="relative grid items-center gap-10 md:grid-cols-[1.3fr_1fr]">
      <div>
        <span class="eyebrow"><Icon name="sparkle" size={16} /> Order &amp; booking</span>
        <h2 class="mt-3 text-3xl md:text-4xl text-cream">
          Get the Yumme Momos app — <span class="text-fry">instant discount</span> on your first order.
        </h2>
        <p class="mt-4 max-w-xl text-cream/75">
          Install the app to order and book in a tap, track your order, and unlock app-only offers. Available on Android and iOS.
        </p>
        <StoreBadges class="mt-7" />
      </div>

      <!-- Device mockup slot (TODO: client to supply app screenshot) -->
      <div class="mx-auto w-full max-w-[220px]">
        <div class="relative aspect-[9/19] rounded-[2rem] border-[6px] border-cream/15 bg-gradient-to-b from-chili/30 to-ink shadow-2xl">
          <div class="absolute left-1/2 top-2.5 h-1.5 w-16 -translate-x-1/2 rounded-full bg-cream/25"></div>
          <div class="grid h-full place-items-center text-center text-cream/40">
            <div>
              <Icon name="app" size={40} class="mx-auto" />
              <p class="mt-2 px-4 text-xs">App screenshot<br/>slot</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
